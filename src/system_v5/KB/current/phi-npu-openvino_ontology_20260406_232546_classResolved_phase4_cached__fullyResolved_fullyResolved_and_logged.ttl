ex:SensorActivation a owl:Class ;
    rdfs:label "SensorActivation" ;
    rdfs:comment "The process of activating a sensor, which may involve physical actions such as shaking the sensor to connect it with an application." ;
    rdfs:subClassOf ex:Action .

ex:SensorPatchApplication a owl:Class ;
    rdfs:label "SensorPatchApplication" ;
    rdfs:comment "A guide that details the process of applying a sensor patch to a sensor device, including cleaning and preparation of the skin and the sensor." ;
    rdfs:subClassOf ex:Action .

ex:SensorPatchApplicationVideo a owl:Class ;
    rdfs:label "SensorPatchApplicationVideo" ;
    rdfs:comment "A video tutorial that visually demonstrates the process of applying a sensor patch to a sensor device, which may include specific techniques or tips not covered in the written guide." ;
    rdfs:subClassOf ex:Action ;
    owl:equivalentClass ex:SensorPatchRemovalVideo .

ex:SensorPatchApplicationVideoGuide a owl:Class ;
    rdfs:label "SensorPatchApplicationVideoGuide" ;
    rdfs:comment "A video guide that visually demonstrates the process of applying a sensor patch to a sensor device, which may include specific techniques or tips not covered in the written guide." ;
    rdfs:subClassOf ex:Action ;
    owl:equivalentClass ex:SensorPatchRemovalVideo .

ex:SensorPatchAttachmentVideo a owl:Class ;
    rdfs:label "SensorPatchAttachmentVideo" ;
    rdfs:comment "A video tutorial that provides a visual demonstration of how to attach a new sensor patch to a sensor device, which may include specific techniques or tips not covered in the written guide." ;
    rdfs:subClassOf ex:Action ;
    owl:equivalentClass ex:SensorPatchRemovalVideo .

ex:SensorPatchAttachmentVideoGuide a owl:Class ;
    rdfs:label "SensorPatchAttachmentVideoGuide" ;
    rdfs:comment "A video guide that provides a visual demonstration of the process of attaching a new sensor patch to a sensor device, which may include specific techniques or tips not covered in the written guide." ;
    rdfs:subClassOf ex:Action ;
    owl:equivalentClass ex:SensorPatchRemovalVideo .

ex:SensorPatchMaterialHandling a owl:Class ;
    rdfs:label "SensorPatchMaterialHandling" ;
    rdfs:comment "Instructions and precautions for handling used sensor patches, including the removal of patch material from sensors and the disposal of non-reusable plastic material." ;
    rdfs:subClassOf ex:Action .

ex:SensorPatchRemovalVideoGuideAdditional a owl:Class ;
    rdfs:label "SensorPatchRemovalVideoGuideAdditional" ;
    rdfs:comment "A video guide that may include additional, possibly more detailed, instructions or demonstrations for the removal of a sensor patch." ;
    rdfs:subClassOf ex:Action,
        ex:SensorPatchRemovalVideoGuide,
        ex:SensorPatchRemovalVideoGuideAdditional .

ex:SensorPatchRemovalVideoNote a owl:Class ;
    rdfs:label "SensorPatchRemovalVideoNote" ;
    rdfs:comment "A video guide that may include additional notes or tips for the removal of a sensor patch, which may not be fully captured in the written guide." ;
    rdfs:subClassOf ex:Action,
        ex:SensorPatchRemovalVideoGuide ;
    owl:equivalentClass ex:SensorPatchRemovalVideo .

ex:SensorPositioning a owl:Class ;
    rdfs:label "SensorPositioning" ;
    rdfs:comment "The act of placing a sensor in a particular location, which can be critical for its effectiveness." ;
    rdfs:subClassOf ex:PhysicalObject,
        ex:SensorPositioning .

ex:SensorRangeRequirement a owl:Class ;
    rdfs:label "SensorRangeRequirement" ;
    rdfs:comment "The specific physical range within which a sensor must be located relative to a device for data transfer to be successful, as determined by the application's functionality." ;
    rdfs:subClassOf ex:Quality .

ex:SleepCycle a owl:Class ;
    rdfs:label "SleepCycle" ;
    rdfs:comment "A full cycle of sleep that progresses through various stages of sleep, including REM and non-REM stages, and is repeated multiple times throughout the night. Each cycle typically lasts about 90 minutes." ;
    rdfs:subClassOf ex:Event,
        ex:SleepPattern .

ex:SleepDuration a owl:Class ;
    rdfs:label "SleepDuration" ;
    rdfs:comment "The total amount of time spent sleeping, typically measured over a 24-hour period, which can be influenced by sleep patterns and sleep quality." ;
    rdfs:subClassOf ex:SleepPattern,
        ex:TimeInterval .

ex:SleepPosition a owl:Class ;
    rdfs:label "SleepPosition" ;
    rdfs:comment "The physical position in which an individual sleeps, which can include lying on the back, side, or stomach, and can influence sleep quality and comfort." ;
    rdfs:subClassOf ex:Quality,
        ex:SleepPattern .

ex:SleepQuality a owl:Class ;
    rdfs:label "SleepQuality" ;
    rdfs:comment "A measure of how well an individual slept during a given period, often assessed by the proportion of time spent in restorative deep sleep versus lighter stages of sleep, and the number of awakenings or disturbances experienced." ;
    rdfs:subClassOf ex:Quality,
        ex:SleepPattern .

