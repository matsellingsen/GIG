ex:ThirdPartyServiceProvider a owl:Class ;
    rdfs:label "ThirdPartyServiceProvider" ;
    rdfs:comment "External organizations that process personal data on behalf of the service provider, as mentioned in the privacy policy, including Plausible Analytics, Formspark, Zendesk, and Sentry." ;
    rdfs:subClassOf ex:SocialObject .

ex:Author a owl:Class ;
    rdfs:label "Author" ;
    rdfs:comment "An individual or group of individuals who have contributed to the creation of a scholarly work, such as a research article or a book." ;
    rdfs:subClassOf ex:Publication,
        ex:SocialObject .

ex:HealthcareApp a owl:Class ;
    rdfs:label "HealthcareApp" ;
    rdfs:comment "A software application designed to assist healthcare professionals and patients in tracking and improving physical activity and overall health." ;
    rdfs:subClassOf ex:InformationObject .

ex:AppFeature a owl:Class ;
    rdfs:label "AppFeature" ;
    rdfs:comment "A specific functionality or capability provided by a software application that enhances its usability or adds value to the user experience." ;
    rdfs:subClassOf ex:InformationRealization .

ex:Entity a owl:Class ;
    rdfs:label "Entity" ;
    rdfs:comment "Anything: real, possible, or imaginary, which some modeller wants to talk about for some purpose." ;
    owl:equivalentClass ex:Entity .

ex:HealthcareProfessional a owl:Class ;
    rdfs:label "HealthcareProfessional" ;
    rdfs:comment "A person who is trained and licensed to provide healthcare services, such as doctors, nurses, therapists, or physical therapists." ;
    rdfs:subClassOf ex:HealthcareProfessionalRole,
        ex:PhysicalObject .

ex:HospitalStudy a owl:Class ;
    rdfs:label "HospitalStudy" ;
    rdfs:comment "A research project or investigation conducted within a hospital setting to evaluate the effectiveness of a particular intervention or treatment." ;
    rdfs:subClassOf ex:Collection .

ex:SensorPatchRemovalVideo a owl:Class ;
    rdfs:label "SensorPatchRemovalVideo" ;
    rdfs:comment "A video tutorial that visually demonstrates the process of removing a sensor patch, which may include specific techniques or tips not covered in the written guide." ;
    rdfs:subClassOf ex:Action .

ex:HealthcareDevice a owl:Class ;
    rdfs:label "HealthcareDevice" ;
    rdfs:comment "Any physical tool or piece of equipment used in the context of healthcare, such as medical instruments, machines, or devices." ;
    rdfs:subClassOf ex:HealthcareProfessional,
        ex:PhysicalObject .

ex:PatchType a owl:Class ;
    rdfs:label "PatchType" ;
    rdfs:comment "A specific category of patches characterized by its level of activity, such as 'low activity' or 'high activity'." ;
    rdfs:subClassOf ex:InformationRealization .

ex:SensorPatchRemovalGuide a owl:Class ;
    rdfs:label "SensorPatchRemovalGuide" ;
    rdfs:comment "A guide that specifically focuses on the process of removing a sensor patch from a sensor device, including any special techniques or precautions." ;
    rdfs:subClassOf ex:Action,
        ex:SensorPatchRemovalGuide .

ex:ActivityDataTypes a owl:Class ;
    rdfs:label "ActivityDataTypes" ;
    rdfs:comment "Various forms of data collected by sensors, such as acceleration, temperature, and motion intensity, used in research to analyze human activity." ;
    rdfs:subClassOf ex:InformationObject .

ex:SensorPatch a owl:Class ;
    rdfs:label "SensorPatch" ;
    rdfs:comment "A wearable device, often a small piece of clothing or adhesive, that is used to monitor various health-related metrics." ;
    rdfs:subClassOf ex:PhysicalObject .

