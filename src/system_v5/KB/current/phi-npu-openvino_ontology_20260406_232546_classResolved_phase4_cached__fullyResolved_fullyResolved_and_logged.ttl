    rdfs:comment "A significant result or conclusion drawn from the analysis of data in a research study, which contributes to the understanding of the subject matter." ;
    rdfs:subClassOf ex:InformationObject,
        ex:Publication .

ex:MovementFrequency a owl:Class ;
    rdfs:label "MovementFrequency" ;
    rdfs:comment "The rate at which a movement occurs, used to distinguish between different types of physical activity, such as walking or running." ;
    rdfs:subClassOf ex:MovementType,
        ex:Quality .

ex:OnlineVisualizationTool a owl:Class ;
    rdfs:label "OnlineVisualizationTool" ;
    rdfs:comment "A digital tool that allows users to view and interact with data or information over the internet, in this context, for visualizing patient activity." ;
    rdfs:subClassOf ex:InformationRealization .

ex:ParticipantTableEnhancements a owl:Class ;
    rdfs:label "ParticipantTableEnhancements" ;
    rdfs:comment "Improvements or additional features added to a table or data table interface that provide more information or functionality, such as the ability to expand rows for more details." ;
    rdfs:subClassOf ex:Action,
        ex:ParticipantTableEnhancements .

ex:ProjectManagementImprovements a owl:Class ;
    rdfs:label "ProjectManagementImprovements" ;
    rdfs:comment "Enhancements or new features in project management tools that simplify the creation, organization, and tracking of projects, often aimed at improving user experience and efficiency." ;
    rdfs:subClassOf ex:Action,
        ex:ProjectManagementImprovements .

ex:RetentionPeriod a owl:Class ;
    rdfs:label "RetentionPeriod" ;
    rdfs:comment "The duration for which personal data is stored, as stated in the privacy policy, which is up to 30 days in this context." ;
    rdfs:subClassOf ex:TimeInterval .

ex:SensorManagementWebApp a owl:Class ;
    rdfs:label "SensorManagementWebApp" ;
    rdfs:comment "A web application designed to manage, view, and export data collected from various sensors." ;
    rdfs:subClassOf ex:InformationObject,
        ex:ResearchProject .

ex:SensorPatchRemovalVideoGuide a owl:Class ;
    rdfs:label "SensorPatchRemovalVideoGuide" ;
    rdfs:comment "A video guide that focuses on the removal of a sensor patch, potentially including a video demonstration of the removal process." ;
    rdfs:subClassOf ex:Action,
        ex:SensorPatchRemovalGuide ;
    owl:equivalentClass ex:SensorPatchRemovalVideo .

ex:SensorWarning a owl:Class ;
    rdfs:label "SensorWarning" ;
    rdfs:comment "A caution or advisory related to the use of sensors, such as the importance of turning them off to save battery life as mentioned in the source text." ;
    rdfs:subClassOf ex:Action,
        ex:SensorManagement .

ex:Service a owl:Class ;
    rdfs:label "Service" ;
    rdfs:comment "A specific offering provided by a company or organization, typically to customers or clients." ;
    rdfs:subClassOf ex:SocialObject .

ex:SleepStage a owl:Class ;
    rdfs:label "SleepStage" ;
    rdfs:comment "A distinct period of sleep characterized by specific patterns of brain and muscle activity, as well as other measurable physiological variables. Sleep stages are typically identified during a sleep cycle and include stages of light sleep, deep sleep, and REM (Rapid Eye Movement) sleep." ;
    rdfs:subClassOf ex:Event,
        ex:SleepPattern .

ex:SoftwareRelease a owl:Class ;
    rdfs:label "SoftwareRelease" ;
    rdfs:comment "A specific version or iteration of a software application or system, characterized by a set of features, improvements, and bug fixes." ;
    rdfs:subClassOf ex:InformationRealization,
        ex:PhysicalObject,
        ex:SocialObject .

ex:SoftwareUIElement a owl:Class ;
    rdfs:label "SoftwareUIElement" ;
    rdfs:comment "An element of the user interface of a software application, such as breadcrumbs, navigation sections, or memory status indicators." ;
    rdfs:subClassOf ex:PhysicalObject .

ex:SupportChannel a owl:Class ;
    rdfs:label "SupportChannel" ;
    rdfs:comment "A platform or method provided by an organization for customers to reach out with inquiries, issues, or feedback." ;
    rdfs:subClassOf ex:SocialObject .

ex:System a owl:Class ;
