ex:DataSecurityArticle a owl:Class ;
    rdfs:label "DataSecurityArticle" ;
    rdfs:comment "A written work that discusses the data security aspects and compliance of a specific technology or system." ;
    rdfs:subClassOf ex:CompanyLogo,
