        ex:Study,
        owl:NamedIndividual ;
    ex:chunk_id 30 .

ex:PilotPackage a owl:Class ;
    rdfs:label "PilotPackage" ;
    rdfs:comment "A limited-time promotional offer that allows the use of a product or service in a specific setting, with a set number of uses or a limited time frame." ;
    rdfs:subClassOf ex:Collection .

ex:SmartphoneApp a owl:Class ;
    rdfs:label "SmartphoneApp" ;
    rdfs:comment "A software application designed to run on smartphones, providing various functionalities and services." ;
    rdfs:subClassOf ex:DataTransferProcess,
        ex:InformationObject ;
    owl:equivalentClass ex:MobileApplication .

ex:BatteryStatusIndicator a owl:Class ;
    rdfs:label "BatteryStatusIndicator" ;
    rdfs:comment "A visual or interactive element that provides information about the current charge level or estimated remaining time of a battery." ;
    rdfs:subClassOf ex:InformationRealization .

ex:ParticipantInformation a owl:Class ;
    rdfs:label "ParticipantInformation" ;
    rdfs:comment "Data or details related to an individual who is part of a study or monitoring process, including personal and sensor-related information." ;
    rdfs:subClassOf ex:InformationObject .

ex:WebApp a owl:Class ;
    rdfs:label "WebApp" ;
    rdfs:comment "An application that operates over the web, providing services or resources through a network, typically accessed via a web browser." ;
    rdfs:subClassOf ex:SocialObject ;
    owl:equivalentClass ex:WebApplication .

ex:TimeInterval a owl:Class ;
    rdfs:label "TimeInterval" ;
    rdfs:comment "A specific period or duration of time." ;
    rdfs:subClassOf ex:MeasurementUnit,
        ex:TimeInterval .

ex:PickUpLocation a owl:Class ;
    rdfs:label "PickUpLocation" ;
    rdfs:comment "A specific physical location where items can be collected, often a store or a designated area for drop-off and pick-up." ;
    rdfs:subClassOf ex:CustomerSupportContact,
        ex:PhysicalObject,
        ex:PickUpLocation .

ex:Quality a owl:Class ;
    rdfs:label "Quality" ;
    rdfs:comment "Any aspect of an Entity (but not a part of it), which cannot exist without that Entity. For example, the color of a physical object or the duration of an event." .

ex:ActivityCategory a owl:Class ;
    rdfs:label "ActivityCategory" ;
    rdfs:comment "A classification of physical activities into distinct groups based on the type of movement or behavior." ;
    rdfs:subClassOf ex:Collection,
        ex:Event,
        ex:MeasurementUnit,
        ex:SocialObject .

ex:UserInterface a owl:Class ;
    rdfs:label "UserInterface" ;
    rdfs:comment "The part of the software application that directly interacts with the user, often consisting of menus, buttons, and other elements that allow the user to perform actions or make selections." ;
    rdfs:subClassOf ex:PhysicalObject,
        ex:SocialObject .

ex:MeasurementUnit a owl:Class ;
    rdfs:label "MeasurementUnit" ;
    rdfs:comment "A standard unit used to quantify a physical quantity, such as time or intensity, in the context of physical activities." ;
    rdfs:subClassOf ex:PhysicalObject .

ex:Publication a owl:Class ;
    rdfs:label "Publication" ;
    rdfs:comment "A medium through which scholarly work, such as research articles, books, or reports, is disseminated to the public or a specific community." ;
    rdfs:subClassOf ex:Collection,
        ex:InformationObject,
        ex:SocialObject .

ex:Collection a owl:Class ;
    rdfs:label "Collection" ;
    rdfs:comment "Any collection of objects, events, or other entities, such as a group of people or a dataset." .

ex:InformationRealization a owl:Class ;
    rdfs:label "InformationRealization" ;
    rdfs:comment "A physical object or event that realizes an information object. For example, a physical printed document or a digital file on a hard drive." .

ex:WebApplication a owl:Class ;
    rdfs:label "WebApplication" ;
    rdfs:comment "A software application that is designed to be used over the internet, typically accessed through a web browser." ;
    rdfs:subClassOf ex:InformationObject,
        ex:PhysicalObject,
        ex:UserInterface .

ex:Action a owl:Class ;
    rdfs:label "Action" ;
    rdfs:comment "An Event with at least one agent that participates in it, and that executes a task." .

ex:Event a owl:Class ;
    rdfs:label "Event" ;
    rdfs:comment "Any physical, social, or mental process, event, or state. Events unfold in time and have objects as participants." .

ex:Study a owl:Class ;
    rdfs:label "Study" ;
    rdfs:comment "A systematic investigation into a defined area of interest or field of knowledge, often to generate new insights or information." ;
    rdfs:subClassOf ex:SocialObject .

ex:PhysicalObject a owl:Class ;
    rdfs:label "PhysicalObject" ;
    rdfs:comment "Any Object that has a proper space region. Examples include people, equipment, sensors, and buildings." .

ex:InformationObject a owl:Class ;
    rdfs:label "InformationObject" ;
    rdfs:comment "A piece of information, such as a text, a word, a picture, or data, independently from how it is concretely realized." .

ex:SocialObject a owl:Class ;
    rdfs:label "SocialObject" ;
    rdfs:comment "Any Object that exists only within some social context, such as organizations, laws, plans, or projects." .

