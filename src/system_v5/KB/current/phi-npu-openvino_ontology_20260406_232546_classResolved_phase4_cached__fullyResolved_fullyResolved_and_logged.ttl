ex:PeerReviewedArticle a owl:Class ;
    rdfs:label "PeerReviewedArticle" ;
    rdfs:comment "A scholarly publication that has undergone a rigorous review process by experts in the field to validate its research and findings." ;
    rdfs:subClassOf ex:InformationObject,
        ex:Publication .

ex:TeamMember a owl:Class ;
    rdfs:label "TeamMember" ;
    rdfs:comment "An individual who is part of a team, typically associated with a group of people with a common purpose or interest, such as a company or organization." ;
    rdfs:subClassOf ex:SocialObject .

ex:LegalBasis a owl:Class ;
    rdfs:label "LegalBasis" ;
    rdfs:comment "The justification for processing personal data, as required by law or for specific purposes, such as contract performance or legitimate interests." ;
    rdfs:subClassOf ex:SocialObject .

ex:HealthStudy a owl:Class ;
    rdfs:label "HealthStudy" ;
    rdfs:comment "A research project focused on understanding and improving health outcomes, often involving the collection and analysis of data related to health and disease." ;
    rdfs:subClassOf ex:SocialObject ;
    owl:equivalentClass ex:ClinicalStudy .

ex:Protocol a owl:Class ;
    rdfs:label "Protocol" ;
    rdfs:comment "A detailed plan or agreement for conducting a study or trial, outlining the objectives, design, and methodology." ;
    rdfs:subClassOf ex:SocialObject,
        ex:Study .

ex:ApplicationFeature a owl:Class ;
    rdfs:label "ApplicationFeature" ;
    rdfs:comment "A specific functionality or component within a software application that provides a particular service or capability to the user." ;
    rdfs:subClassOf ex:PhysicalObject ;
    owl:equivalentClass ex:AppFeature .

